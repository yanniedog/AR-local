# Ingest output (large); keep only scripts in git
runs/
tmp_smoke_out/
__pycache__/
.daily-state/
*.pyc
*.sqlite
*.sqlite-shm
*.sqlite-wal
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
runs/*.*

node_modules/

# Env / secrets (never commit)
.env
.env.*
!.env.example

# Local git worktrees (agent parallel checkouts)
.worktrees/
_wt-*/
*-wt/
*-pr/
tmp/

# Agent auditor session artifacts (local only)
.git/auditor/

# Bot wait gate anchor state (local; override with AR_BOT_WAIT_STATE_DIR)
.ar-bot-wait/

# Agent session artifacts (local only)
.ar-mobile-audit/
.ar-pr-watch/

*.log
.tmp*.*
*.png

# Mobile app build artifacts
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/ios/
mobile/android/
**/app-payload/

# Track the mobile app's committed assets despite the global *.png ignore above.
!mobile/assets/icon.png
!mobile/assets/adaptive-icon.png
!mobile/assets/splash.png
!mobile/assets/favicon.png
!mobile/assets/banks/*.png

# Local scratch: ad-hoc probe/debug scripts and PR-thread helpers (not source)
.pi-*
.pi_*
_pi_*
_run_pi_*
.pr[0-9]*-threads*
.pr[0-9]*.graphql
.reply-thread-*.json
.resolve-*.mjs
.resolve-thread-*.json

# Local runtime data store (state/stream stores; not source)
/data/

# projectmem persistent memory — local per-machine (CLAUDE.md is committed; memory is not)
/.projectmem/
