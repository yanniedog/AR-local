{
  "name": "ar-local",
  "private": true,
  "description": "Local CDR ingest + dashboard (workflow parity with AustralianRates; no Cloudflare)",
  "scripts": {
    "wait-for-bots": "node wait_for_bots.mjs",
    "pr:bot-feedback-check": "node scripts/pr-bot-feedback-check.mjs",
    "pr:gates:check": "node scripts/pr-gates-check.mjs",
    "pr:watch-once": "node scripts/pr-watch-once.mjs",
    "pr:bot-feedback-audit": "node scripts/pr-bot-feedback-check.mjs --audit-merged --limit 20",
    "pr:gate-logic:verify": "node scripts/verify-pr-gate-logic.mjs",
    "close-loop:check": "node scripts/close-loop-check.mjs",
    "ship:closeout:strict": "python ship_closeout_strict.py",
    "verify:local": "python verify_local.py",
    "verify:pi": "python verify_local.py --base-url=http://100.78.28.10/",
    "pi:deploy:verify": "python pi_deploy_verify.py --verify",
    "pi:deploy": "python pi_deploy_verify.py --deploy",
    "pi:deploy:dry-run": "python pi_deploy_verify.py --deploy --dry-run",
    "pi:needs-deploy": "python pi_deploy_verify.py --needs-pi",
    "git:graph-hygiene": "git fetch origin --prune",
    "chief:scan": "node scripts/chief-scan.mjs",
    "agent:auditor": "node scripts/agent-auditor-scan.mjs",
    "branch-protection:apply": "node scripts/apply-branch-protection.mjs",
    "crashlytics:sync-issues": "node scripts/crashlytics-to-github-issues.mjs"
  }
}
