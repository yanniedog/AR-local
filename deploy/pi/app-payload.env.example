# AR-local mobile-app payload publishing — environment for the daily ingest.
#
# Install on the Pi as /etc/ar-local/app-payload.env (mode 0600), or use:
#   sudo sh deploy/pi/install-app-payload-token.sh <github_pat>
#
# Then re-render the service units and reload:
#   sh deploy/pi/install-pi-systemd.sh /srv/ar-local
#   sudo systemctl daemon-reload
#
# GH_TOKEN: a GitHub fine-grained PAT scoped to the repo with
#           "Contents: Read and write" (covers Releases). Never commit this file.

AR_LOCAL_APP_PAYLOAD=1
GH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
