{
  "expo": {
    "name": "Australian Rates",
    "slug": "ar-local-rates",
    "owner": "yannieyannies-team",
    "scheme": "arrates",
    "version": "1.0.0",
    "description": "Daily Australian home loan, savings and term-deposit rates from open banking (CDR) data. Browse, filter, compare and watch rates — works offline.",
    "primaryColor": "#1f6feb",
    "githubUrl": "https://github.com/yanniedog/AR-local",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0b0f17",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eyex.australianrates",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ]
      }
    },
    "android": {
      "package": "com.eyex.australianrates",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f17"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "REQUEST_INSTALL_PACKAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1f6feb"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0f17",
          "image": "./assets/splash.png",
          "imageWidth": 180
        }
      ],
      "expo-asset",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBCrashlytics"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "repo": "yanniedog/AR-local",
      "releaseTag": "app-payload-latest",
      "manifestUrl": "https://github.com/yanniedog/AR-local/releases/download/app-payload-latest/manifest.json",
      "apkReleaseTag": "app-apk-latest",
      "apkManifestUrl": "https://github.com/yanniedog/AR-local/releases/download/app-apk-latest/app-apk-latest.json",
      "router": {},
      "eas": {
        "projectId": "69c08d63-b618-43f1-86b9-2556eef82104"
      }
    }
  }
}
