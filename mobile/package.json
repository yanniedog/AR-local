{
  "name": "ar-local-rates",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "doctor": "npx expo-doctor",
    "eas-build-pre-install": "node scripts/ensure-firebase-config.mjs",
    "preexport:android": "node scripts/ensure-firebase-config.mjs",
    "export:android": "expo export --platform android",
    "preexport:ios": "node scripts/ensure-firebase-config.mjs",
    "export:ios": "expo export --platform ios",
    "preexport": "node scripts/ensure-firebase-config.mjs",
    "export": "expo export --platform all",
    "ci": "npm run doctor && npm run typecheck && npm run lint && npm run test -- --ci && npm run export",
    "sample": "node scripts/build-sample.mjs",
    "icons": "python scripts/make-icons.py"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@microsoft/react-native-clarity": "^4.6.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.0",
    "@react-native-firebase/crashlytics": "^24.1.0",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-background-fetch": "~14.0.9",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "fflate": "^0.8.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "qrcode": "^1.5.4",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.0"
    },
    "@expo/metro-config": {
      "postcss": "^8.5.10"
    }
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@shopify/flash-list))"
    ]
  }
}
