    "expo-file-system": "~18.0.4",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.3",
    "expo-network": "~7.0.4",
    "expo-notifications": "~0.29.11",
    "expo-router": "~4.0.7",
    "expo-splash-screen": "~0.29.13",
